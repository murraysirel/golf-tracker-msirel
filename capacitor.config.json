{
  "appId": "com.loopercaddie.app",
  "appName": "Looper",
  "webDir": "www",
  "backgroundColor": "#0b1520",
  "server": {
    "allowNavigation": [
      "loopercaddie.com",
      "*.supabase.co",
      "api.open-meteo.com",
      "fonts.googleapis.com",
      "fonts.gstatic.com",
      "cdnjs.cloudflare.com",
      "browser.sentry-cdn.com"
    ]
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#0b1520"
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0b1520"
    },
    "SplashScreen": {
      "backgroundColor": "#0b1520",
      "launchAutoHide": true,
      "launchShowDuration": 0,
      "showSpinner": false
    }
  }
}
